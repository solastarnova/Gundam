# 複製為 .env 並填入實際值

# App locale for UI messages (languages/{locale}/common.json, api/*.json, mail|membership.json, view/*.json); default zh_HK
# APP_LOCALE=zh_HK

# database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mydb
DB_USER=root
DB_PASSWORD=


# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id

# Firebase Authentication
FIREBASE_CREDENTIALS=storage/firebase-service-account.json
# 網頁應用程式設定（Firebase Console → 專案設定 → 一般 → 您的應用程式）
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_STORAGE_BUCKET=
# 設為 true 時顯示 Facebook 登入（須在 Firebase 啟用 Facebook 並設定應用程式）
FIREBASE_ENABLE_FACEBOOK=true

# Mail Configuration 
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=高達模型商城

# DeepSeek AI 客服（可選；未設定 API Key 時會回覆「尚未配置」）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_HISTORY=10
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_TOKENS=800
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_CATALOG_LIMIT=150
