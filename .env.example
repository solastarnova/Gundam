# 複製為 .env 並填入實際值

# App locale for UI messages (languages/{locale}/common.json, api/*.json, mail|membership.json, view/*.json); default zh_HK
# APP_LOCALE=zh_HK

# database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mydb
DB_USER=root
DB_PASSWORD=


# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id

# Firebase Authentication
FIREBASE_CREDENTIALS=storage/firebase-service-account.json
# 網頁應用程式設定（Firebase Console → 專案設定 → 一般 → 您的應用程式）
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_STORAGE_BUCKET=
# 設為 true 時顯示 Facebook 登入（須在 Firebase 啟用 Facebook 並設定應用程式）
FIREBASE_ENABLE_FACEBOOK=true

# Mail Configuration 
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=高達模型商城

# Lalamove 同城配送 API v3（Partner Portal → Developers；Sandbox 金鑰前綴 pk_test_ / sk_test_）
# LALAMOVE_SANDBOX=true
# LALAMOVE_MARKET=HK
# LALAMOVE_LANGUAGE=zh_HK
LALAMOVE_API_KEY=
LALAMOVE_API_SECRET=
# 結帳即時報價：取貨點（與 Lalamove POST /v3/quotations 第一個 stop 一致）
# LALAMOVE_PICKUP_LAT=22.3354735
# LALAMOVE_PICKUP_LNG=114.1761581
# LALAMOVE_PICKUP_ADDRESS=Innocentre, 72 Tat Chee Ave, Kowloon Tong
# OpenStreetMap Nominatim 要求可識別的 User-Agent
# NOMINATIM_USER_AGENT=YourShop/1.0 (contact@example.com)

# MapTiler（結帳地址地圖向量底圖；見 https://www.maptiler.com/ ）
# 未設定時會使用 OpenStreetMap 光栅底圖
# MAPTILER_API_KEY=

# DeepSeek AI 客服（可選；未設定 API Key 時會回覆「尚未配置」）
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_HISTORY=10
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_TOKENS=800
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_CATALOG_LIMIT=150
